{
    "name": "react-starter",
    "private": true,
    "version": "2.0.0",
    "description": "A React boilerplate with Atomic Design methodology. This boilerplate also includes libraries that support basic features such as fetching, global state management, and routing systems.",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:ssr": "tsx server.ts",
        "build": "tsc -b && vite build",
        "build:ssr": "pnpm build:client && pnpm build:server",
        "build:client": "cross-env VITE_USE_SSR=true vite build --outDir dist/client",
        "build:server": "vite build --outDir dist/server --ssr src/entry-server.tsx",
        "build:image": "run-script-os",
        "build:image:darwin:linux": "chmod +x $(pwd)/scripts/build-image.sh && $(pwd)/scripts/build-image.sh",
        "build:image:win32": "call scripts\\build-image.bat",
        "run:container": "run-script-os",
        "run:container:darwin:linux": "chmod +x $(pwd)/scripts/run-container.sh && $(pwd)/scripts/run-container.sh",
        "run:container:win32": "call scripts\\run-container.bat",
        "lint": "eslint .",
        "preview": "vite preview",
        "preview:ssr": "cross-env NODE_ENV=production tsx server.ts",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui"
    },
    "dependencies": {
        "@koa/router": "^15.0.0",
        "@reduxjs/toolkit": "^2.11.2",
        "axios": "^1.13.2",
        "dotenv": "^17.2.3",
        "koa": "^3.0.0",
        "koa-compress": "^5.1.1",
        "koa-conditional-get": "^3.0.0",
        "koa-etag": "^4.0.0",
        "koa-helmet": "^8.0.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-redux": "^9.2.0",
        "react-router-dom": "^7.12.0",
        "sirv": "^3.0.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@tailwindcss/vite": "^4.1.18",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/koa": "^2.15.0",
        "@types/koa-compress": "^4.0.6",
        "@types/koa-conditional-get": "^2.0.3",
        "@types/koa-etag": "^3.0.3",
        "@types/koa__router": "^12.0.4",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.5",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.1",
        "@vitest/coverage-v8": "^3.1.4",
        "@vitest/ui": "^3.1.4",
        "chokidar": "^5.0.0",
        "cross-env": "^10.1.0",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "jsdom": "^26.1.0",
        "run-script-os": "^1.1.6",
        "tailwindcss": "^4.1.18",
        "tsx": "^4.19.4",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.46.4",
        "vite": "^7.2.4",
        "vitest": "^3.1.4"
    },
    "engines": {
        "node": ">=v24"
    }
}
