# Environment Variables

# ============================================================================
# Client-side only
# These variables are only accessible in the browser/client context
# ============================================================================

# Application Configuration
VITE_PUBLIC_APP_NAME=
VITE_PUBLIC_APP_URL=http://localhost:3000
VITE_PUBLIC_APP_BASE_PATH=/

# API Configuration
VITE_PUBLIC_API_BASE_URL=https://api.example.com
VITE_PUBLIC_API_VERSION=/v1


# ============================================================================
# Server-side only (if in SSR mode)
# In SSR mode, these variables are only accessible in Node.js/server context
# In non-SSR mode, these variables are bundled into the client-side code (build time)
# ============================================================================

# App/Server Port
VITE_APP_PORT=

# Runtime Environment Configuration
# Set to 'true' to enable SSR and runtime env from process.env
# Set to 'false' to use client-side rendering (default)
VITE_USE_SSR=false